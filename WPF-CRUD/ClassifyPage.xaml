<Page x:Class="WPF_CRUD.ClassifyPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WPF_CRUD"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ClassifyPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />            
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Margin="20" Grid.Row="0">
            <Image  Source="/Images/Classify/rhino.jpg" MaxWidth="800" MaxHeight="550" Stretch="Uniform" HorizontalAlignment="Center" 
                    VerticalAlignment="Center" Margin="20" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
            <TextBlock FontSize="20" Text="This is " VerticalAlignment="Center"/>
            <TextBox FontSize="20"  Width="150" Name="txtClassify" Height="30" SelectionChanged="txtClassify_SelectionChanged"/>            
            <Button Name="btnCheck" Click="btnCheck_Click" Width="30" Height="30">
                <Image Name="imgCheck" Source="/Images/Buttons/question1.png" Width="30" Height="30" Stretch="Uniform" HorizontalAlignment="Center" 
                    VerticalAlignment="Center"></Image>
            </Button>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <TextBlock Name="tbClassify" FontSize="20" TextWrapping="Wrap" HorizontalAlignment="Center" VerticalAlignment="Center"
                   TextAlignment="Center" Margin="20,10,20,20" MaxWidth="400" />
        <ComboBox Name="cbCategory" Grid.Row="2" Margin="0,10" HorizontalAlignment="Center" VerticalAlignment="Center">
        <ComboBoxItem />            
        </ComboBox>
        </StackPanel>
    </Grid>
</Page>
