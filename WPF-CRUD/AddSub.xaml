<Page x:Class="WPF_CRUD.AddSub"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:local="clr-namespace:WPF_CRUD"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddSub">
    <Viewbox>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="100"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        
        <!--#region FN + SN -->

        <Grid Grid.Row="1" 
              Grid.Column="1"
              >
            <Grid.RowDefinitions>                
                <RowDefinition Height="*"></RowDefinition>
                <RowDefinition Height="*"></RowDefinition>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>                
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="2*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
                            
            <Button x:Name="btnOperator"                                                
                        Margin="5"
                        Grid.Row="0" 
                        Grid.Column="0"
                        Grid.RowSpan="2"
                    Command="{Binding Path=OperatorCommand}"
                        Content="+"
                        FontSize="100"
                        VerticalContentAlignment="Top">
                    
            </Button>
            <Button x:Name="btnFirstNum" 
                    Grid.Row="0" 
                    Grid.Column="1"
                    Command="{Binding Path=FirstNumberCommand}"
                    Margin="5,5"
                    Content="FN"
                    FontSize="50"
                    HorizontalContentAlignment="Center">                
            </Button>
            <Button x:Name="btnSecondNum"
                    Grid.Row="1" 
                    Grid.Column="1"
                    Command="{Binding Path=SecondNumberCommand}"
                    Margin="5,5"
                    Content="SN"
                    FontSize="50"
                    HorizontalContentAlignment="Center"></Button>
        </Grid>
        <!--#endregion FN + SN -->

        <!--#region Results -->
        <Grid Grid.Row="2" Grid.Column="1" >
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" BorderBrush="Black" BorderThickness="5" Width="350" />
            <Button Grid.Row="1" 
                    Command="{Binding Path=OperatorCommand}"
                    Content="Add/Sub" 
                    FontSize="70"></Button>
                
        </Grid>
        <!--#endregion Results -->
        
        <!--#region Counting icons -->
        
        <Grid Grid.Row="2" Grid.Column="2">
            <ScrollViewer     
                x:Name="MyScrollViewer"
                PreviewMouseWheel="MyScrollViewer_PreviewMouseWheel"
                HorizontalScrollBarVisibility="Hidden"
                VerticalScrollBarVisibility="Hidden"
                Margin="10,0,10,5"
                Height="150"
                Width="300"   
                >
                <ItemsControl ItemsSource="{Binding CountingIcons}">

                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="5" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Image Name="imgCountingIcon"
                                   Source ="{Binding ImagePath}" 
                                    Margin="5" 
                                    Height="120" 
                                    Width="180" 
                                    MouseMove="imgCountingIcon_MouseMove"
                                   MouseDown="imgCountingIcon_MouseDown"
                                   />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!--#endregion Counting icons -->
        
    </Grid>
    </Viewbox>
</Page>
