<Window x:Class="WPF_CRUD.HomePage" 
          xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
          Title="HomePage" WindowState="Maximized"  WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Navigation Menu -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Background="LightGray" Margin="0,0,0,10">
            <Button Name="btnHome" Content="Home" Width="100" Height="40" Margin="10,5" Click="BtnHome_Click"/>
            <Button Name="btnAddSub" Content="Add Sub" Width="100" Height="40" Margin="10,5" Click="btnAddSub_Click"/>
            <Button Name="btnClassify" Content="Classify" Width="100" Height="40" Margin="10,5" Click="BtnClassify_Click"/>
            <Button Name="btnHindiWord" Content="Hindi Words" Width="120" Height="40" Margin="10,5" Click="btnHindiWord_Click"/>
            <Button Name="btnMediaPlayer" Content="Media Player" Width="120" Height="40" Margin="10,5" Click="BtnMediaPlayer_Click"/>
            <Button Name="btnAbout" Content="About" Width="100" Height="40" Margin="10,5" Click="BtnAbout_Click"/>
            <Button Name="btnSettings" Content="Settings" Width="100" Height="40" Margin="10,5" Click="BtnSettings_Click"/>
        </StackPanel>
        
        <!-- Frame for Page Navigation -->
        <Frame Grid.Row="1" 
               Name="MainFrame" 
               NavigationUIVisibility="Hidden" 
               Background="White"/>
    </Grid>
</Window>