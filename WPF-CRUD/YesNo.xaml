<Page x:Class="WPF_CRUD.YesNo"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WPF_CRUD"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="YesNo">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4*"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid Grid.Row="0" Grid.Column="0" 
              Grid.RowSpan="4"
              Name="OptionsGrid" >
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="4*"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Viewbox Margin="10">                    
                <ListBox 
                    Height="2000"
                    Name="lbOptions"
                    Grid.Column="0"
                    
                    Width="Auto"
                    ScrollViewer.VerticalScrollBarVisibility="Hidden"
                    FontSize="120"
                    HorizontalContentAlignment="Center"
                    HorizontalAlignment="Left"
                    ItemsSource="{Binding ImageCategories, Mode=TwoWay}"
                    SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                    />
                    
                </Viewbox>
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"></RowDefinition>
                        <RowDefinition Height="*"></RowDefinition>
                        <RowDefinition Height="*"></RowDefinition>
                    </Grid.RowDefinitions>
                    <Button Name="btnPrevious"
                            Style="{StaticResource NoHoverButtonStyle}"
                            Margin="10"
                            Padding="0"
                            Grid.Row="1" 
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            >
                        <Viewbox Stretch="Uniform"
                                 Margin="15"
                                 >
                            <Path Data="M 1,0 L 0,0.5 L 1,1 Z"
                                  Stretch="Uniform"
                                  Fill="WhiteSmoke"/>
                        </Viewbox>
                    </Button>

                    <Button Name="btnPositive"
                            Style="{StaticResource NoHoverButtonStyle}"
                            MaxWidth="40" MaxHeight="40"
                            Background="LawnGreen"
                            Grid.Row="2"/>
                </Grid>
                <Image Name="questionImage"
                   Grid.Column="2"
                   Source="{Binding Path=MainImage.ImagePath, Mode=TwoWay}"
                   Height="Auto" Width="Auto"                   
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
                <Grid Grid.Column="3">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"></RowDefinition>
                        <RowDefinition Height="*"></RowDefinition>
                        <RowDefinition Height="*"></RowDefinition>
                    </Grid.RowDefinitions>
                    <Button Name="btnNext"
                            Margin="10"
                            Padding="0"
                            Grid.Row="1"
                            Style="{StaticResource NoHoverButtonStyle}"
                            BorderThickness="1"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            >
                        <Viewbox Stretch="Uniform"
                                 Margin="15"
                                 >
                            <Path Data="M 0,0 L 1,0.5 L 0,1 Z"
                                  Stretch="Uniform"
                                  Fill="WhiteSmoke"/>
                        </Viewbox>
                    </Button>
                    <Button Name="btnNegative"
                            Style="{StaticResource NoHoverButtonStyle}"
                            MaxWidth="40"
                            MaxHeight="40"
                            Background="Crimson"
                            Grid.Row="2"/>
                </Grid>
            </Grid>

        </Grid>
        <Grid Grid.Row="4" Grid.Column="0"
              Grid.ColumnSpan="2"
              Grid.RowSpan="2"
              Name="QnAGrid" >
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" 
                        Margin="10"
                        Background="LightGreen">
                <Viewbox                     
                    HorizontalAlignment="Left"                    
                           >
                    
                    <TextBlock Padding="10,5"
                           Text="Question:"
                           FontFamily="Comic Sans MS"
                           FontWeight="Bold"
                           VerticalAlignment="Center"                             
                           FontSize="15">   
                        
                    </TextBlock>
                    
                </Viewbox>
                </Border>
                <Border Grid.Row="1" 
                        Margin="10"
                        Background="LightGreen">
                <Viewbox
                    HorizontalAlignment="Left"
                           >
                    <TextBlock Padding="10,5"
                           Text="Answer:"
                           FontFamily="Comic Sans MS"
                           FontWeight="Bold"
                           VerticalAlignment="Center"                           
                           FontSize="15">
                </TextBlock>
                </Viewbox>
                </Border>
            </Grid>            
        </Grid>
        <Grid Grid.Row="0" Grid.Column="1"
              Grid.RowSpan="2"
              Name="YesButtonGrid" >
            <Button Name="YesButton"
                    Style="{StaticResource NoHoverButtonStyle}"
                    FontWeight="Bold"                    
                    Foreground="WhiteSmoke"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="10"
                    >
                <Viewbox>
                    <TextBlock Text="Yes" Padding="10" />
                </Viewbox>
            </Button>

        </Grid>
        <Grid Grid.Row="2" Grid.Column="1"
              Grid.RowSpan="2"
              Name="NoButtonGrid" >
            <Button Name="NoButton"
                    Style="{StaticResource NoHoverButtonStyle}"                    
                    FontWeight="Bold"                    
                    Foreground="WhiteSmoke"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="10"
                    >
                <Viewbox>
                    <TextBlock Text="No" Padding="10" />
                </Viewbox>
            </Button>
        </Grid>
    </Grid>
</Page>
