<Window x:Class="WPF_CRUD.PopUpSelect"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF_CRUD"
        mc:Ignorable="d"
        Title="Select" 
        Height="300"
        Width="500"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        >
    <Border x:Name="brdPopUp" BorderBrush="Black"
        BorderThickness="2"
        CornerRadius="20"
        Width="450"
        Height="270"
        Background="#FF1E1E1E"
        >
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="2*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock x:Name="txtMessage" Grid.Row="0"                       
                       FontSize="20"
                       Foreground="Black"
                       FontWeight="Bold"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
            <WrapPanel Grid.Row="1"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center">
            <TextBox x:Name="txtInput" 
                     FontSize="80"
                     Foreground="Black"
                     FontWeight="Bold"                         
                     TextAlignment="Center"
                     VerticalContentAlignment="Center"
                     VerticalAlignment="Center"
                     HorizontalAlignment="Center"
                     Padding="10"
                     Width="200"
                     MinHeight="110"/>
            <ScrollViewer   
                x:Name="MyScrollViewer"
                PreviewMouseWheel="MyScrollViewer_PreviewMouseWheel"
                HorizontalScrollBarVisibility="Hidden"
                VerticalScrollBarVisibility="Hidden"
                Background="White"
                Margin="10,0,10,5"
                MinHeight="110"
                Width="240"
                >
                    <ItemsControl x:Name="icOptions" 
                                  >

                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                                <Border 
                                    BorderThickness="1"
                                    BorderBrush="Black"
                                    Background="AliceBlue"
                                    Margin="5">
                            <Image Name="imgSelection"  
                                    Height="100" 
                                    Width="100" 
                                    Source="{Binding ImagePath}"
                                   Cursor="Hand"
                                   />
                                </Border>
                            </DataTemplate>
                    </ItemsControl.ItemTemplate>

                </ItemsControl>
            </ScrollViewer>
            </WrapPanel>
            <Button x:Name="btnOk" Grid.Row="2"
                    Style="{StaticResource RectangleButtonStyle}"
                    Content="OK"
                    FontSize="20"                    
                    FontWeight="Bold"
                    Foreground="Black"
                    Width="100"
                    Height="40"
                    Margin="0,10,0,20"
                    HorizontalAlignment="Center"
                    Click="btnOk_Click"/>
        </Grid>
    </Border>
</Window>
